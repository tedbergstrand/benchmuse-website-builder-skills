# ==========================================================================
# benchmuse-website-builder-skills
# ==========================================================================

# OS / editor cruft
.DS_Store
.vscode/
*.swp

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# Internal archive — test/demo data from development, not shipped
archive/

# Generated distribution bundle — rebuilt from the source tree on demand.
# The repo itself IS the toolkit; users clone or download-zip from GitHub.
distribution/

# Generated by the toolkit as a luthier runs it — personal data
# (excluded so the repo stays template-clean; each luthier's copy
# generates these locally)
luthier-profile.json
pipeline-status.json
handoffs/*
!handoffs/.gitkeep

# The built website — regenerated from the skills each run
website/

# Node / build artifacts (only for React/Vite stack)
node_modules/
dist/
.env
.env.local

# Legacy
.instagram-auth/
